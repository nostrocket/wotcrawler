{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the crawler's /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["nostr", "web-of-trust", "crawler", "OBS-05"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "Nostr Web-of-Trust Crawler",
  "uid": "wot-crawler-obs",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Frontier depth",
      "description": "Pubkeys waiting in the crawl frontier (status='discovered').",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "frontier_depth",
          "legendFormat": "frontier depth",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Crawl coverage",
      "description": "Fraction of reachable pubkeys whose follow list has been fetched.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "crawl_coverage_ratio",
          "legendFormat": "coverage",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Fetch rate / latency",
      "description": "Per-batch relay fetch latency and rate, from the fetch_duration_seconds histogram.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(fetch_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 fetch latency",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(fetch_duration_seconds_count[5m]))",
          "legendFormat": "fetches/sec",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Staleness distribution",
      "description": "Distribution of follow-list age since last fetch (staleness_age_seconds histogram).",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(staleness_age_seconds_bucket[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Relay health",
      "description": "Per-relay consecutive failures, active relay count, and rate-limit / block notices.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "relay_consecutive_failures",
          "legendFormat": "max consecutive failures",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "relay_active_count",
          "legendFormat": "active relays",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(relay_rate_limited_total[5m]))",
          "legendFormat": "rate-limited notices/sec",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(relay_blocked_total[5m]))",
          "legendFormat": "blocked notices/sec",
          "refId": "D"
        }
      ]
    },
    {
      "id": 6,
      "title": "Validation failures",
      "description": "Ingest-gate rejection counters: forged signatures, unsolicited authors, oversized follow lists, future-dated events.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(ingest_invalid_signature_total[5m]))",
          "legendFormat": "invalid signature/sec",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(ingest_unsolicited_total[5m]))",
          "legendFormat": "unsolicited/sec",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(ingest_oversized_follow_list_total[5m]))",
          "legendFormat": "oversized follow list/sec",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(ingest_future_dated_total[5m]))",
          "legendFormat": "future-dated/sec",
          "refId": "D"
        }
      ]
    }
  ]
}
